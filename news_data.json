    {"id": "39f03a7e9d", "title": "Brands, beware! Microdramas just might be the next metaverse", "summary_original": "Short-form scripted microdramas on apps like ReelShort are attracting brand partnerships, raising questions about whether this format is the next big marketing frontier.", "url": "https://www.fastcompany.com/91543096/microdramas-just-might-be-the-next-metaverse", "source": "Fast Company Co.Design", "category": "general", "published_raw": "2026-06-04T10:00:00"},
    {"id": "6f155b7fd4", "title": "J.Crew's new campaign is an adventurous romp straight out of its 90s catalogs", "summary_original": "Camp Crew, J.Crew's summer campaign, blends nostalgia with new pieces in a series of Instagram posts and a 40-second video.", "url": "https://www.fastcompany.com/91552683/j-crew-summer-camp-campaign", "source": "Fast Company Co.Design", "category": "branding", "published_raw": "2026-06-04T10:00:00"},
    {"id": "c5f2504742", "title": "The Heated Rivalry fleece is finally for sale", "summary_original": "The viral fleece from the hit Canadian TV show Heated Rivalry is now available through Province of Canada after months of social media buzz.", "url": "https://www.fastcompany.com/91552651/heated-rivalry-fleece-finally-for-sale", "source": "Fast Company Co.Design", "category": "general", "published_raw": "2026-06-03T16:05:00"},
    {"id": "2db8527977", "title": "AI-created document fatigue: how I designed my way out of it", "summary_original": "AI promised a leisure revolution but delivered more documents to consume. One designer created a voice-first app to move work away from the desk.", "url": "https://uxdesign.cc/ai-created-document-fatigue-how-i-designed-my-way-out-of-it-1fcd4a565669", "source": "UX Collective", "category": "ai", "published_raw": "Tue, 02 Jun 2026 21:53:50 GMT"},
    {"id": "e927ef8b94", "title": "The most important part of building your taste is to hand it off", "summary_original": "What having taste trapped in your head costs you and your team — and how to externalize design taste effectively.", "url": "https://uxdesign.cc/the-most-important-part-of-building-your-taste-is-to-hand-it-off-be91aeac65d9", "source": "UX Collective", "category": "ui", "published_raw": "Tue, 02 Jun 2026 11:08:16 GMT"},
    {"id": "22a3c83b53", "title": "Default Bias: Who chose your settings?", "summary_original": "People pull toward pre-selected options rather than actively choosing alternatives. The friction of changing something produces consistent gravity toward the status quo.", "url": "https://uxdesign.cc/default-bias-who-chose-your-settings-d2acde25551b", "source": "UX Collective", "category": "ui", "published_raw": "Tue, 02 Jun 2026 11:07:25 GMT"},
    {"id": "d47b19f8dd", "title": "AI meets Sturgeon's Law", "summary_original": "Why does more AI-generated content not mean more quality? Exploring how Sturgeon's Law applies to the age of generative AI.", "url": "https://uxdesign.cc/ai-meets-sturgeons-law-21d17488fc48", "source": "UX Collective", "category": "ai", "published_raw": "Mon, 01 Jun 2026 22:53:56 GMT"},
]

FALLBACK_IMAGES = {
    "ui":       "https://images.unsplash.com/photo-1561070791-2526d30994b5?w=600&q=80",
    "tools":    "https://images.unsplash.com/photo-1618788372246-79faff0c3742?w=600&q=80",
    "ai":       "https://images.unsplash.com/photo-1677442135703-1787eea5ce01?w=600&q=80",
    "branding": "https://images.unsplash.com/photo-1634084462412-b54873c0a56d?w=600&q=80",
    "motion":   "https://images.unsplash.com/photo-1550745165-9bc0b252726f?w=600&q=80",
    "general":  "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=80",
}

blocks = []
for i, item in enumerate(items_raw):
    blocks.append(f"[{i}]\nTITLE: {item['title']}\nSUMMARY: {item['summary_original']}")

prompt = """Du bist ein professioneller Design-Redakteur.
Uebersetze alle Titel und Zusammenfassungen ins Deutsche.
Natuerliches journalistisches Deutsch. Eigennamen behalten (Figma, Adobe, CSS, UX, AI etc.).
Antworte NUR mit JSON-Array, kein weiterer Text:

[{"title": "...", "summary": "..."}]

Nachrichten:
""" + "\n\n".join(blocks)

message = client.messages.create(
    model="claude-opus-4-5",
    max_tokens=4096,
    messages=[{"role": "user", "content": prompt}],
)

import re
raw = message.content[0].text.strip()
raw = re.sub(r"^```json\s*|^```\s*|```$", "", raw, flags=re.MULTILINE).strip()
start = raw.find("[")
end = raw.rfind("]") + 1
translations = json.loads(raw[start:end])

for i, item in enumerate(items_raw):
    item["title_de"] = translations[i]["title"]
    item["summary_de"] = translations[i]["summary"]
    item["image"] = FALLBACK_IMAGES.get(item["category"], FALLBACK_IMAGES["general"])

output = {
    "updated_at": "2026-06-04T11:14:06Z",
    "source_count": 6,
    "item_count": len(items_raw),
    "category_labels": {
        "ui": "UI/UX",
        "tools": "Software & Tools",
        "ai": "KI & Bildrechte",
        "branding": "Branding & Typo",
        "motion": "Motion & Plugins",
        "general": "Design"
    },
    "items": items_raw
}

print(json.dumps(output, ensure_ascii=False, indent=2))
PYEOF

pip install anthropic --break-system-packages -q
python /tmp/translate_news.py > /mnt/user-data/outputs/news_data.json
echo "✅ Bitti"
